    "/posts": {
      "get": {
        "operationId": "get-posts",
        "summary": "Get all posts",
        "description": "Retrieve a paginated list of blog posts with optional filters",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$",
              "description": "Page number"
            },
            "description": "Page number"
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$",
              "description": "Items per page"
            },
            "description": "Items per page"
          },
          {
            "in": "query",
            "name": "published",
            "required": false,
            "schema": {
