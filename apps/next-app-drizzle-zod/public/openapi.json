                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      },
      "post": {
        "operationId": "post-posts",
        "summary": "Create a new post",
        "description": "Create a new blog post with Drizzle-Zod validation",
        "tags": [
