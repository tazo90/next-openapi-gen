        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$",
              "description": "Post ID"
            },
            "description": "Post ID",
            "example": "123"
          }
        ],
        "responses": {
