                "false"
              ],
              "description": "Filter by publication status"
            },
            "description": "Filter by publication status"
          },
          {
            "in": "query",
            "name": "authorId",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d+$",
