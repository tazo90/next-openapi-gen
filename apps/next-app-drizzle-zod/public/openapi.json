  "tags": [
    {
      "name": "Authors"
    },
    {
      "name": "Posts"
    }
  ],
  "components": {
    "schemas": {
      "AuthorIdParams": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Author ID"
          }
        },
        "required": [
          "id"
        ]
      },
      "AuthorResponseSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "Author display name"
          },
          "email": {
            "type": "string",
            "maxLength": 255,
            "format": "email",
            "description": "Author email address"
          },
          "bio": {
            "type": "string",
            "nullable": true,
            "description": "Author biography"
          },
          "avatarUrl": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "format": "uri",
            "description": "Author avatar URL"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "bio",
          "avatarUrl",
          "createdAt"
        ]
      },
      "UpdateAuthorSchema": {
        "type": "object",
        "properties": {
          "avatarUrl": {
            "type": "string",
            "format": "uri",
            "description": "Author avatar URL"
          },
          "bio": {
            "type": "string",
            "maxLength": 280,
            "description": "Author biography"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Author display name"
          }
        },
        "required": []
      },
      "AuthorsQueryParams": {
        "type": "object",
        "properties": {
          "page": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Page number"
          },
          "limit": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Items per page"
          },
          "search": {
            "type": "string",
            "description": "Case-insensitive author search"
          },
          "sort": {
            "type": "string",
            "enum": [
              "name",
              "recent"
            ],
            "description": "Sort mode"
          }
        }
      },
      "CreateAuthorSchema": {
        "type": "object",
        "properties": {
          "bio": {
            "type": "string",
            "maxLength": 280,
            "description": "Author biography"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Author email address"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Author display name"
          }
        },
        "required": [
          "email",
          "name"
        ]
      },
      "AuthorBatchStatusUpdateSchema": {
        "type": "object",
        "properties": {
          "authorIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "minItems": 1,
            "description": "Author IDs to update"
          },
          "status": {
            "type": "string",
            "enum": [
              "featured",
              "standard"
            ],
            "description": "Visibility bucket to assign"
          }
        },
        "required": [
          "authorIds",
          "status"
        ]
      },
      "PostIdParams": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Post ID"
          }
        },
        "required": [
          "id"
        ]
      },
      "PostResponseSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string",
            "maxLength": 255,
            "description": "Post title"
          },
          "slug": {
            "type": "string",
            "maxLength": 255,
            "description": "URL-friendly slug"
          },
          "excerpt": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "description": "Post excerpt"
          },
          "content": {
            "type": "string",
            "description": "Full post content"
          },
          "published": {
            "type": "boolean",
            "description": "Publication status"
          },
          "viewCount": {
            "type": "integer",
            "description": "Number of views"
          },
          "authorId": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        },
        "required": [
          "id",
          "title",
          "slug",
          "excerpt",
          "content",
          "published",
          "viewCount",
          "authorId",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdatePostSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 255,
            "description": "Post title"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "URL-friendly slug"
          },
          "excerpt": {
            "type": "string",
            "maxLength": 500,
            "description": "Short excerpt"
          },
          "content": {
            "type": "string",
            "minLength": 10,
            "description": "Post content"
          },
          "published": {
            "type": "boolean",
            "description": "Publication status"
          }
        },
        "required": []
      },
      "PostsQueryParams": {
        "type": "object",
        "properties": {
          "page": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Page number"
          },
          "limit": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Items per page"
          },
          "published": {
            "type": "string",
            "enum": [
              "true",
              "false"
            ],
            "description": "Filter by publication status"
          },
          "authorId": {
            "type": "string",
            "pattern": "^\\d+$",
            "description": "Filter by author ID"
          }
        }
      },
      "CreatePostSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 255,
            "description": "Post title"
          },
          "slug": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "URL-friendly slug"
          },
          "excerpt": {
            "type": "string",
            "maxLength": 500,
            "description": "Short excerpt of the post"
          },
          "content": {
            "type": "string",
            "minLength": 10,
            "description": "Post content in markdown"
          },
          "published": {
            "type": "boolean",
            "description": "Whether the post is published"
          },
          "authorId": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "ID of the post author"
          }
        },
        "required": [
          "title",
          "slug",
          "content",
          "authorId"
        ]
      }
    },
    "responses": {
      "400": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid request parameters"
                },
                "code": {
                  "type": "string",
                  "example": "400"
                }
              }
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Authentication required"
                },
                "code": {
                  "type": "string",
                  "example": "401"
                }
              }
            }
          }
        }
      },
      "403": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Access denied"
                },
                "code": {
                  "type": "string",
                  "example": "403"
                }
              }
            }
          }
        }
      },
      "500": {
        "description": "Internal Server Error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "An unexpected error occurred"
                },
                "code": {
                  "type": "string",
                  "example": "500"
                }
              }
            }
          }
        }
      }
    }
  }
}