{
  "openapi": "3.0.0",
  "info": {
    "title": "Next.js Pages Router API",
    "version": "1.0.0",
    "description": "API documentation for Next.js Pages Router example"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CreateProductSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description"
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Product price"
          },
          "stock": {
            "type": "integer",
            "minimum": 0,
            "default": 0,
            "description": "Stock quantity"
          },
          "category": {
            "type": "string",
            "description": "Product category"
          }
        },
        "required": [
          "name",
          "price",
          "stock",
          "category"
        ]
      },
      "CreateUserSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "description": "Full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "description": "Password (min 8 characters)"
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "ProductIdParamsSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Product ID"
          }
        },
        "required": [
          "id"
        ]
      },
      "ProductListParamsSchema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "Filter by category"
          },
          "minPrice": {
            "type": "number",
            "description": "Minimum price"
          },
          "maxPrice": {
            "type": "number",
            "description": "Maximum price"
          },
          "page": {
            "type": "number",
            "description": "Page number"
          },
          "limit": {
            "type": "number",
            "description": "Results per page"
          }
        }
      },
      "ProductSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Product ID"
          },
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description"
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Product price"
          },
          "stock": {
            "type": "integer",
            "minimum": 0,
            "description": "Stock quantity"
          },
          "category": {
            "type": "string",
            "description": "Product category"
          }
        },
        "required": [
          "id",
          "name",
          "price",
          "stock",
          "category"
        ]
      },
      "UpdateUserSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "description": "Full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          }
        }
      },
      "UploadRequestSchema": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "description": "Uploaded filename"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "avatar",
              "attachment"
            ],
            "description": "Upload purpose"
          }
        },
        "required": [
          "fileName",
          "purpose"
        ]
      },
      "UploadResponseSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Upload identifier"
          },
          "fileName": {
            "type": "string",
            "description": "Stored filename"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "avatar",
              "attachment"
            ],
            "description": "Upload purpose"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Public download URL"
          }
        },
        "required": [
          "id",
          "fileName",
          "purpose",
          "url"
        ]
      },
      "UserCookiesSchema": {
        "type": "object",
        "properties": {
          "session": {
            "type": "string",
            "description": "Session cookie"
          },
          "locale": {
            "type": "string",
            "enum": [
              "en",
              "de",
              "pl"
            ],
            "description": "UI locale"
          }
        },
        "required": [
          "session"
        ]
      },
      "UserErrorResponseSchema": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Machine-readable error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "UserIdParamsSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          }
        },
        "required": [
          "id"
        ]
      },
      "UserListParamsSchema": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "description": "Page number"
          },
          "limit": {
            "type": "number",
            "description": "Results per page"
          },
          "search": {
            "type": "string",
            "description": "Search query"
          }
        }
      },
      "UserRequestHeadersSchema": {
        "type": "object",
        "properties": {
          "X-Tenant-Id": {
            "type": "string",
            "description": "Tenant identifier"
          },
          "X-Request-Id": {
            "type": "string",
            "format": "uuid",
            "description": "Request trace id"
          }
        },
        "required": [
          "X-Tenant-Id"
        ]
      },
      "UserSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "name": {
            "type": "string",
            "description": "Full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          },
          "createdAt": {
            "type": "string",
            "description": "Creation date"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "createdAt"
        ]
      }
    },
    "responses": {}
  },
  "paths": {
    "/products": {
      "get": {
        "operationId": "get-products",
        "summary": "Get all products",
        "description": "Retrieve a list of products with optional filtering",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "category",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filter by category"
            },
            "description": "Filter by category"
          },
          {
            "in": "query",
            "name": "minPrice",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Minimum price"
            },
            "description": "Minimum price"
          },
          {
            "in": "query",
            "name": "maxPrice",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Maximum price"
            },
            "description": "Maximum price"
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Page number"
            },
            "description": "Page number"
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Results per page"
            },
            "description": "Results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProductSchema"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-products",
        "summary": "Create a new product",
        "description": "Add a new product to the catalog",
        "tags": [
          "Products"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductSchema"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductSchema"
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "operationId": "get-products-{id}",
        "summary": "Get product by ID",
        "description": "Retrieve a specific product by its ID",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Product ID"
            },
            "description": "Product ID",
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductSchema"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "put-products-{id}",
        "summary": "Update product",
        "description": "Update an existing product's information",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Product ID"
            },
            "description": "Product ID",
            "example": "123"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductSchema"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductSchema"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-products-{id}",
        "summary": "Delete product",
        "description": "Remove a product from the catalog",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Product ID"
            },
            "description": "Product ID",
            "example": "123"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/uploads": {
      "get": {
        "operationId": "get-uploads",
        "summary": "Download upload instructions",
        "description": "Returns plain-text upload instructions for Pages Router transport coverage.",
        "tags": [
          "Uploads"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-uploads",
        "summary": "Upload an attachment",
        "description": "Demonstrates multipart-style documentation and auth-heavy Pages Router handlers.",
        "tags": [
          "Uploads"
        ],
        "parameters": [],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadRequestSchema"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponseSchema"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "get-users",
        "summary": "List users",
        "description": "Retrieve a list of all users with optional filtering",
        "tags": [
          "Users",
          "Pages router"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Page number"
            },
            "description": "Page number"
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Results per page"
            },
            "description": "Results per page"
          },
          {
            "in": "query",
            "name": "search",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Search query"
            },
            "description": "Search query"
          },
          {
            "in": "header",
            "name": "X-Tenant-Id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Tenant identifier"
            },
            "description": "Tenant identifier"
          },
          {
            "in": "header",
            "name": "X-Request-Id",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Request trace id"
            },
            "description": "Request trace id"
          },
          {
            "in": "cookie",
            "name": "session",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Session cookie"
            },
            "description": "Session cookie"
          },
          {
            "in": "cookie",
            "name": "locale",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "en",
                "de",
                "pl"
              ],
              "description": "UI locale"
            },
            "description": "UI locale"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserSchema"
                  }
                }
              }
            },
            "headers": {
              "X-Total-Count": {
                "description": "Total users in the result set",
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-users",
        "summary": "Create user",
        "description": "Create a new user account",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "X-Tenant-Id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Tenant identifier"
            },
            "description": "Tenant identifier"
          },
          {
            "in": "header",
            "name": "X-Request-Id",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Request trace id"
            },
            "description": "Request trace id"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserSchema"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSchema"
                }
              }
            },
            "headers": {
              "Location": {
                "description": "URL of the created user",
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "get-users-{id}",
        "summary": "Get user by ID",
        "description": "Retrieve a specific user by their ID",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "User ID"
            },
            "description": "User ID",
            "example": "123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSchema"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "put-users-{id}",
        "summary": "Update user (legacy)",
        "description": "Update an existing user's information\n\nDeprecated: Use PATCH /api/v2/users/{id} instead; scheduled for removal 2026-12-01.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "User ID"
            },
            "description": "User ID",
            "example": "123"
          }
        ],
        "deprecated": true,
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserSchema"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSchema"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-users-{id}",
        "summary": "Delete user",
        "description": "Remove a user from the system",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "description": "User ID"
            },
            "description": "User ID",
            "example": "123"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Products"
    },
    {
      "name": "Uploads"
    },
    {
      "name": "Users"
    }
  ]
}
