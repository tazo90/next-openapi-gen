{
  "name": "tanstack-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "generate": "openapi-gen generate",
    "start": "vite preview",
    "lint": "oxlint --config ../../packages/oxlint-config/base.json . --ignore-path ../../.gitignore --deny-warnings",
    "format": "oxfmt --config ../../packages/oxfmt-config/oxfmt.json --ignore-path ../../.gitignore .",
    "format:check": "oxfmt --config ../../packages/oxfmt-config/oxfmt.json --ignore-path ../../.gitignore --check .",
    "check": "pnpm format:check && pnpm lint"
  },
  "dependencies": {
    "@scalar/api-reference-react": "catalog:",
    "@tanstack/react-router": "catalog:tanstack",
    "@tanstack/react-start": "catalog:tanstack",
    "react": "catalog:tanstack",
    "react-dom": "catalog:tanstack"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:tanstack",
    "@types/react-dom": "catalog:tanstack",
    "@vitejs/plugin-react": "catalog:tanstack",
    "ajv": "catalog:",
    "next-openapi-gen": "workspace:*",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:tanstack"
  }
}
