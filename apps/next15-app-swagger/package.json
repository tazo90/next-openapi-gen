  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "next-openapi-gen": "workspace:*",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "swagger-ui-react": {
      "react": "$react",
      "react-dom": "$react-dom"
