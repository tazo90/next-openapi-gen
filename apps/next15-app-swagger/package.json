{
  "name": "next-15-swagger",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint --config ../../packages/oxlint-config/base.json . --ignore-path ../../.gitignore --deny-warnings",
    "format": "oxfmt --config ../../packages/oxfmt-config/oxfmt.json --ignore-path ../../.gitignore .",
    "format:check": "oxfmt --config ../../packages/oxfmt-config/oxfmt.json --ignore-path ../../.gitignore --check .",
    "check": "pnpm format:check && pnpm lint"
  },
  "dependencies": {
    "next": "catalog:app-next15",
    "react": "catalog:app-next15",
    "react-dom": "catalog:app-next15",
    "swagger-ui": "catalog:",
    "swagger-ui-react": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:app-next15",
    "@types/react": "catalog:app-next15",
    "@types/react-dom": "catalog:app-next15",
    "next-openapi-gen": "workspace:*",
    "typescript": "catalog:"
  },
  "overrides": {
    "swagger-ui-react": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
