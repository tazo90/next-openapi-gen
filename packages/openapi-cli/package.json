{
  "name": "@workspace/openapi-cli",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm clean && tsc",
    "format": "oxfmt --config ../oxfmt-config/oxfmt.json --ignore-path ../../.gitignore .",
    "format:check": "oxfmt --config ../oxfmt-config/oxfmt.json --ignore-path ../../.gitignore --check .",
    "lint": "oxlint --config ../oxlint-config/base.json . --ignore-path ../../.gitignore --deny-warnings",
    "test:coverage": "pnpm --dir ../.. test:coverage:openapi-cli"
  },
  "dependencies": {
    "@workspace/openapi-core": "workspace:*",
    "@workspace/openapi-framework-next": "workspace:*",
    "@workspace/openapi-framework-react-router": "workspace:*",
    "@workspace/openapi-framework-tanstack": "workspace:*",
    "@workspace/openapi-init": "workspace:*",
    "commander": "catalog:",
    "fs-extra": "catalog:",
    "ora": "catalog:"
  },
  "devDependencies": {
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.27.0"
}
