{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**", "templates/**", "tsconfig.tsbuildinfo"]
    },
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "outputs": ["tsconfig.tsbuildinfo"]
    }
  }
}
