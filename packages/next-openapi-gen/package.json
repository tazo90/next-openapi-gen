{
  "name": "next-openapi-gen",
  "version": "0.10.5",
  "description": "Automatically generate OpenAPI 3.0 documentation from Next.js projects, with support for Zod schemas and TypeScript types.",
  "keywords": [
    "api",
    "api-docs",
    "docs",
    "drizzle",
    "nextjs",
    "openapi",
    "react",
    "redoc",
    "scalar",
    "swagger",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "author": "Mariusz Winnik",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tazo90/next-openapi-gen.git"
  },
  "bin": {
    "next-openapi-gen": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "pnpm format:check && pnpm lint && pnpm test",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "build": "pnpm clean && tsc",
    "format": "oxfmt --config ../oxfmt-config/oxfmt.json --ignore-path ../../.gitignore .",
    "format:check": "oxfmt --config ../oxfmt-config/oxfmt.json --ignore-path ../../.gitignore --check .",
    "lint": "oxlint --config ../oxlint-config/base.json . --ignore-path ../../.gitignore --deny-warnings",
    "lint:fix": "oxlint --config ../oxlint-config/base.json . --ignore-path ../../.gitignore --fix --deny-warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "release": "np --no-cleanup --no-tests",
    "version": "conventional-changelog -p angular -i ../../CHANGELOG.md -s -n ../../.changelogrc.cjs && git add ../../CHANGELOG.md"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "commander": "catalog:",
    "fs-extra": "catalog:",
    "js-yaml": "catalog:",
    "ora": "catalog:"
  },
  "devDependencies": {
    "@types/babel__traverse": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:package-types",
    "@vitest/ui": "catalog:",
    "conventional-changelog-cli": "catalog:",
    "np": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.27.0",
  "np": {
    "packageManager": "pnpm",
    "anyBranch": false,
    "branch": "main",
    "cleanup": false,
    "tests": false,
    "2fa": false,
    "releaseDraft": false
  }
}
