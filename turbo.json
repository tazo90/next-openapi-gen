{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "CI",
    "COVERAGE_SCOPE",
    "E2E_APP",
    "FORCE_COLOR",
    "NEXT_OPENAPI_GEN_TIMING",
    "NODE_ENV"
  ],
  "tasks": {
    "//#knip": {
      "dependsOn": ["next-openapi-gen#build"],
      "outputs": []
    },
    "//#knip:ci": {
      "dependsOn": ["next-openapi-gen#build"],
      "outputs": []
    },
    "//#test:e2e": {
      "cache": false,
      "outputs": []
    },
    "//#test:integration": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "//#transit": {
      "dependsOn": ["^transit"]
    },
    "test:coverage": {
      "dependsOn": ["transit"],
      "outputs": ["coverage/**"]
    },
    "//#test:unit": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "tsconfig.tsbuildinfo"]
    },
    "check": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "format:check": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": ["tsconfig.tsbuildinfo"]
    }
  }
}
