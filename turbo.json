{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "//#test:e2e": {
      "cache": false,
      "outputs": []
    },
    "//#test:integration": {
      "outputs": []
    },
    "//#test:unit": {
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "tsconfig.tsbuildinfo"]
    },
    "check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    }
  }
}
