{
  "name": "next-openapi-gen-workspace",
  "private": true,
  "license": "MIT",
  "author": "Mariusz Winnik",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tazo90/next-openapi-gen.git"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check build",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "lint": "turbo run lint",
    "lint:staged": "lint-staged",
    "prepare": "simple-git-hooks",
    "test": "turbo run test",
    "release": "pnpm --filter next-openapi-gen release",
    "version": "pnpm --filter next-openapi-gen version"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "latest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:staged",
    "commit-msg": "pnpm exec commitlint --edit \"$1\""
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxfmt --config ./packages/oxfmt-config/oxfmt.json --ignore-path .gitignore",
      "oxlint --config ./packages/oxlint-config/base.json --ignore-path .gitignore --deny-warnings"
    ],
    "*.{json,jsonc,md,mdx,yml,yaml,css,scss,html,toml}": "oxfmt --config ./packages/oxfmt-config/oxfmt.json --ignore-path .gitignore"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.27.0"
}
